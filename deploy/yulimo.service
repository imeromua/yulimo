[Unit]
Description=Yulimo FastAPI Backend
After=network.target postgresql.service

[Service]
User=anubis
WorkingDirectory=/home/anubis/yulimo/backend
EnvironmentFile=/home/anubis/yulimo/backend/.env
ExecStart=/home/anubis/yulimo/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
